# Copy this file to `.env` and fill in your real values.
# Do NOT commit `.env` to GitHub.
# If your Telegram bot token was ever exposed, revoke it in BotFather and issue a new one.

# -----------------------------------------------------------------------------
# Required Telegram settings
# -----------------------------------------------------------------------------
# Bot token issued by @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:replace_with_your_real_bot_token

# Numeric Telegram user ID allowed to control the bot.
# Only messages from this user will be accepted.
TELEGRAM_ALLOWED_USER_ID=123456789

# Numeric Telegram chat ID where the bot listens.
# For a supergroup this is usually a negative integer, e.g. -1001234567890.
TELEGRAM_CHAT_ID=-1001234567890

# -----------------------------------------------------------------------------
# Optional pacing / log display settings
# -----------------------------------------------------------------------------
# Minimum interval between durable outbound Telegram messages.
CODEX_TG_SEND_INTERVAL_SEC=1.0

# Number of live log lines to keep in the rolling Telegram tail message.
CODEX_TG_TAIL_LINES=60

# Minimum interval between edits of the rolling live tail message.
CODEX_TG_TAIL_EDIT_SEC=0.8

# -----------------------------------------------------------------------------
# Optional presentation settings
# -----------------------------------------------------------------------------
# Custom label used when the script creates a dedicated Telegram topic. (e.g. Codex Choonsik)
# CODEX_TG_TOPIC_LABEL=My Codex Bridge

# strftime pattern used for the topic timestamp.
# CODEX_TG_TOPIC_TIME_FORMAT=%m-%d %H:%M

# Optional suffix appended to every user prompt before it is sent to Codex.
# Useful for house rules such as language or coding style preferences.
# CODEX_TG_PROMPT_SUFFIX=Always answer in English and keep code comments detailed.
